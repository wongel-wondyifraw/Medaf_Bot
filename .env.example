BOT_TOKEN=your_telegram_bot_token_here

# Telegram Bot API endpoint. Leave default unless your ISP blocks api.telegram.org.
TELEGRAM_API_ROOT=https://api.telegram.org

# Render/webhook mode. Leave false for local development unless you expose a
# public HTTPS tunnel. On Render set TELEGRAM_WEBHOOK_URL to your service URL.
TELEGRAM_USE_WEBHOOK=true
TELEGRAM_WEBHOOK_URL=https://your-render-service.onrender.com
TELEGRAM_WEBHOOK_PATH=/telegram/webhook

# Optional HTTP/SOCKS proxy used for BOTH the bot and the Shein scraper.
PROXY_URL=

# Optional Telegram chat ID that receives error notifications.
ADMIN_CHAT_ID=

# Secret password for /admin command (first successful login adds user to admins table).
ADMIN_PASSWORD=change-me-to-a-strong-password

# Telegram user ID that receives the daily health report and sees the
# "Health Report" button in the admin panel (defaults to 1041346091).
HEALTH_REPORT_CHAT_ID=1041346091

# --- Scraping providers ---
# The bot tries providers in PROVIDER_ORDER, skipping any whose key is blank.
PROVIDER_ORDER=scraperapi,retailed,searchapi

# ScraperAPI.com
# Modes: render (10cr) | premium (10cr, residential) | ultra_premium (75cr, paid plans only)
SCRAPERAPI_KEY=
SCRAPERAPI_MODE=render
SCRAPERAPI_COUNTRY=

# Retailed.io (requires manual access approval for the SHEIN endpoint)
RETAILED_API_KEY=

# SearchAPI.io
SEARCHAPI_KEY=
SHEIN_DOMAIN=
SHEIN_CURRENCY=

# --- Pricing ---
PROFIT_MARGIN=30
USD_TO_ETB=165
USD_TO_AED=3.67
EUR_TO_ETB=180
GBP_TO_ETB=210
DELIVERY_COST_ETB=500

# Three-factor pricing engine
PRICING_CEILING_MULTIPLIER=1.20
PRICING_DEFAULT_FACTOR_LOW=0.40
PRICING_DEFAULT_FACTOR_AVG=0.72
PRICING_DEFAULT_FACTOR_HIGH=1.15
PRICING_OBS_BLEND=0.3
# Optional per-category overrides (DB values take precedence unless set):
# PRICING_FACTOR_T_SHIRT_LOW=0.35
# PRICING_FACTOR_T_SHIRT_AVG=0.68
# PRICING_FACTOR_T_SHIRT_HIGH=1.10

# --- AI category detection ---
# Classification order: Gemini (primary) -> Groq (fallback) -> keyword matching.
# Each provider is skipped if its key is blank or it is disabled, and any
# error/timeout/unknown result falls through to the next step automatically.

# Google Gemini Flash (primary) - stronger classification accuracy.
# Get a key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_CATEGORY_ENABLED=true
GEMINI_TIMEOUT_MS=6000

# Groq (disabled fallback) - OpenAI-compatible, generous free tier.
# Set GROQ_CATEGORY_ENABLED=true to re-enable it (runs after Gemini).
# Get a key: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_CATEGORY_ENABLED=false
GROQ_TIMEOUT_MS=6000

# --- Database (PostgreSQL) ---
DATABASE_URL=postgres://user:password@localhost:5432/medafbot
TYPEORM_LOGGING=false
TYPEORM_RUN_MIGRATIONS=true
