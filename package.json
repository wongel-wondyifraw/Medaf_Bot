{
  "name": "shain-bot",
  "version": "1.0.0",
  "description": "Shein Telegram bot built with NestJS + TypeORM",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prestart": "npm run build",
    "start": "node dist/main.js",
    "start:dev": "ts-node -r dotenv/config src/main.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typeorm": "ts-node -r dotenv/config ./node_modules/typeorm/cli.js -d src/database/data-source.ts",
    "migration:generate": "npm run typeorm -- migration:generate",
    "migration:run": "npm run typeorm -- migration:run",
    "migration:revert": "npm run typeorm -- migration:revert"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@nestjs/common": "^11.1.23",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.23",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/typeorm": "^11.0.1",
    "axios": "^1.16.1",
    "dotenv": "^17.4.2",
    "https-proxy-agent": "^9.0.0",
    "nestjs-telegraf": "^2.9.1",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socks-proxy-agent": "^10.0.0",
    "telegraf": "^4.16.3",
    "typeorm": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
