BOT_TOKEN=8777765313:AAGUQUpuP4M4uqiG3V6rVvfRnZf06PWfTGw

# Telegram Bot API endpoint. Leave as default if your network can reach api.telegram.org.
# If your ISP blocks Telegram, deploy the Cloudflare Worker in ./cloudflare-worker.js
# and put its URL here, e.g. https://tg-proxy.yourname.workers.dev
TELEGRAM_API_ROOT=https://api.telegram.org

# Optional HTTP or SOCKS proxy used for BOTH the bot and the Shein scraper.
# Examples:
#   http://user:pass@host:port
#   socks5://127.0.0.1:1080
PROXY_URL=

# Optional Telegram chat ID that receives error notifications.
# Get it by sending /start to your bot and reading the log line "chat.id=...".
ADMIN_CHAT_ID=

# --- Scraping providers ---
# The bot tries providers in PROVIDER_ORDER, skipping any whose key is blank.
# Default: scraperapi,retailed,searchapi
PROVIDER_ORDER=scraperapi,retailed,searchapi

# ScraperAPI.com — free tier: 1000 credits/month.
# JS rendering (render=true) costs 10 credits = ~100 Shein scrapes/month on free tier.
# Modes: render (10cr, free-tier friendly) | premium (10cr, residential) | ultra_premium (75cr, paid plans only)
SCRAPERAPI_KEY=2d5f2667685a6bba93425beeb2ead44f
SCRAPERAPI_MODE=render
# Optional ScraperAPI proxy country override. If blank, auto-picked from URL.
SCRAPERAPI_COUNTRY=

# Retailed.io — free tier: 50 credits one-time. Requires manual access approval.
# Request access at https://retailed.io/datasources/api/shein-product
RETAILED_API_KEY=

# SearchAPI.io
SEARCHAPI_KEY=iGgYpoiFf2MRso5EbJGyXJ25
# Optional override of which Shein storefront SearchAPI talks to.
SHEIN_DOMAIN=
# Optional currency override (e.g. USD, EUR, GBP). Empty = SearchAPI default.
SHEIN_CURRENCY=

# Reseller profit margin (percent) used by src/calculator.js.
# Example: 30 -> sellingPrice = basePrice * 1.30
PROFIT_MARGIN=30

# Exchange rates -> ETB (Ethiopian Birr). Update when market rates change.
USD_TO_ETB=165
EUR_TO_ETB=180
GBP_TO_ETB=210

# Delivery fee added on top of the converted selling price (ETB).
DELIVERY_COST_ETB=500
