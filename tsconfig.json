{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "declaration": false
  },
  "include": [
    "src"
  ],
  "exclude": [
    "node_modules", 
    "dist",
    "src/common/proxy.ts",
    "**/*.spec.ts",
    "**/*.test.ts"
  ]
}